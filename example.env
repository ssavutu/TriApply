# triapply-portal configuration — copy to .env and fill in.
# Every var is read from the environment at runtime (see runtime_config.clj).
# Sinks are independent: a destination only activates when its vars are set,
# and unset ones are skipped. A submission is only reported "received" once
# every configured sink accepts it.

# ── HTTP ────────────────────────────────────────────────────────────────────
PORT=4321

# ── ATS delivery (multipart POST of the application + files) ─────────────────
# Unset to disable the ATS sink.
TRIAPPLY_ATS_URL=https://ats.example.org
TRIAPPLY_ATS_TIMEOUT_MILLIS=10000

# ── Slack notification + Accept/Deny interactivity ───────────────────────────
# All Slack access is via the bot token + Web API (no incoming webhooks).
# The Slack sink activates only when BOTH the bot token and channel are set.
# Bot token (needs chat:write) posts the message and opens the modal.
TRIAPPLY_SLACK_BOT_TOKEN=xoxb-your-bot-token
# Channel ID to post submissions into; invite the bot to this channel.
TRIAPPLY_SLACK_CHANNEL=C0123456789
# Signing secret verifies POSTs to /slack/interactions.
TRIAPPLY_SLACK_SIGNING_SECRET=your-slack-signing-secret
# Timeout for Slack + Sheet HTTP calls.
TRIAPPLY_NOTIFY_TIMEOUT_MILLIS=10000

# ── Google Sheet audit trail (Apps Script web app) ───────────────────────────
# Receives each application, the decision/position, and the file links.
# Unset to disable the Sheet sink.
TRIAPPLY_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# ── Applicant decision email (Gmail API) ─────────────────────────────────────
# Sent to the applicant when a reviewer submits the Slack modal. Sends as the
# notify@thetriangle.org Google mailbox over the Gmail HTTPS API (not SMTP, which
# cloud hosts block outbound; no domain DNS verification needed). One-time setup:
# create an OAuth client (Google Cloud console, Gmail API enabled) and generate a
# refresh token for notify@ with the https://mail.google.com/ scope (e.g. via the
# OAuth Playground). Unset any of these to disable email (the modal reports it).
TRIAPPLY_GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
TRIAPPLY_GMAIL_CLIENT_SECRET=your-oauth-client-secret
TRIAPPLY_GMAIL_REFRESH_TOKEN=your-refresh-token

# Optional overrides — defaults shown. from must be the mailbox (or a send-as
# alias) the refresh token was issued for.
# TRIAPPLY_MAIL_FROM=notify@thetriangle.org
# TRIAPPLY_MAIL_FROM_NAME=The Triangle

# ── Uploaded file storage ────────────────────────────────────────────────────
# Directory the portal writes résumés to; must be the same directory the
# files.triangle.org host serves (see deploy/README.md). Unset to disable
# storage (only filenames are recorded, no links).
TRIAPPLY_UPLOAD_DIR=/var/lib/triapply/uploads
# Public base for the recorded links; access is gated by Authentik at the proxy.
TRIAPPLY_FILE_BASE_URL=https://files.triangle.org
